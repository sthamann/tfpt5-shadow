# Auto-generated build revision stamp (regenerated by build.sh each build)
tex-artefacts/version-auto.tex
tex-artefacts/release-version.txt

# LaTeX build artefacts (removed by build.sh after each successful compile)
*.aux
*.log
*.out
*.toc

# Local drafts / correspondence
list.txt
experiments/older_tests/befund*
alessandro*.html

# Local problem / working notes (not shipped)
problem_*

# External tools cloned locally (reproduced on demand by verification/pyrate/reproduce.sh)
experiments/pyrate/
verification/pyrate/*.generated.txt

# Local secrets (Zenodo token, etc.)
.env

# Local scratch / explanations (not part of the published record)
temp/

# FRB experiment datasets (local copies; see data/README.md)
experiments/frb-tfpt-signatures/data/